# CDP API key for Coinbase AgentKit (optional if using EVM keys below)
# Create at https://portal.cdp.coinbase.com/
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=

# EVM wallet for AgentKit (demo:agentkit) and x402 (demo:x402)
# Use your own wallet; no CDP wallet creation. Public key = address (0x...).
EVM_PUBLIC_KEY=
EVM_PRIVATE_KEY=

# Relayer for x402 demo: settles EIP-3009 on Base Sepolia (pays gas). Needs a little Base Sepolia ETH.
MOCK_402_RELAYER_PRIVATE_KEY=

# Policy server URL (for agent demos). Default: http://localhost:4030
POLICY_SERVER_URL=http://localhost:4030
